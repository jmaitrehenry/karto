{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Karto",
  "version": "0.1.0",
  "identifier": "app.karto.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Karto",
        "width": 1280,
        "height": 820,
        "minWidth": 920,
        "minHeight": 640,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "nsis"],
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "macOS": {
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCNkE0QzYwNTU0MTRDQjkKUldTNVRFRlZZRXhxZTB4QlZWOE12dTJqNDV0LzRhTzZCRVVPeTdOSzdDV3pRMWJxa1dUa0JiSVEK",
      "endpoints": [
        "https://github.com/jmaitrehenry/karto/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
